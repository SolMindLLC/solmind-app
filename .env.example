# SolMind MVP0 environment example
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.

# Public browser-safe Supabase values.
# NEXT_PUBLIC_ variables are exposed to browser/client code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only bootstrap value for first Admin setup.
# Do not prefix this with NEXT_PUBLIC_.
SOLMIND_BOOTSTRAP_TOKEN=

# Server-only Supabase service role key.
# Do not use this in client components, browser code, or NEXT_PUBLIC_ variables.
# Do not enable this until server-only Supabase admin workflows exist.
SUPABASE_SERVICE_ROLE_KEY=
